# Discord Bot Token (https://discord.com/developers/applications)
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 自動回答対象のチャンネルID (カンマ区切りで複数指定可)
TARGET_CHANNEL_IDS=123456789012345678

# 回答に使うClaudeモデル (実行者)
CLAUDE_MODEL=claude-sonnet-4-6

# Advisor Strategy: 判断に迷った時に相談する上位モデル
ADVISOR_MODEL=claude-opus-4-6
ADVISOR_MAX_USES=2

# システムプロンプト (ボットの振る舞いをカスタマイズ)
SYSTEM_PROMPT=あなたはDiscordサーバーの親切なアシスタントです。質問に対して簡潔で分かりやすい日本語で回答してください。

# サーバー履歴の取得設定
HISTORY_FETCH_LIMIT=200
HISTORY_DAYS=30

# 全履歴を取得する優先チャンネル名 (カンマ区切り、部分一致で判定)
PRIORITY_CHANNEL_NAMES=トラブルシューティング,troubleshoot
